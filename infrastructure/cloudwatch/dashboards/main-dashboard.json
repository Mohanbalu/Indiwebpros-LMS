{
  "_comment": "CloudWatch Dashboard — IndiWebPros LMS Production Monitoring",
  "_apply_via": "aws cloudwatch put-dashboard --dashboard-name IndiWebPros-LMS --dashboard-body file://main-dashboard.json",
  "widgets": [
    {
      "type": "text",
      "x": 0, "y": 0, "width": 24, "height": 2,
      "properties": {
        "markdown": "# 🎓 IndiWebPros LMS — Production Dashboard\n**Region**: us-east-1 | **Updated**: Auto-refresh every 60s"
      }
    },
    {
      "type": "metric",
      "x": 0, "y": 2, "width": 8, "height": 6,
      "properties": {
        "title": "🔴 API Server Errors (5xx)",
        "metrics": [["IndiWebPros/LMS", "ServerErrors", { "stat": "Sum", "period": 300 }]],
        "view": "timeSeries",
        "period": 300,
        "yAxis": { "left": { "min": 0 } },
        "annotations": { "horizontal": [{ "color": "#ff6961", "value": 5, "label": "Alert Threshold" }] }
      }
    },
    {
      "type": "metric",
      "x": 8, "y": 2, "width": 8, "height": 6,
      "properties": {
        "title": "💳 Payment Failures",
        "metrics": [
          ["IndiWebPros/LMS", "PaymentFailures", { "stat": "Sum", "period": 300, "label": "Failures" }],
          ["IndiWebPros/LMS", "PaymentSuccesses", { "stat": "Sum", "period": 300, "label": "Successes" }]
        ],
        "view": "timeSeries",
        "period": 300
      }
    },
    {
      "type": "metric",
      "x": 16, "y": 2, "width": 8, "height": 6,
      "properties": {
        "title": "🔒 Authentication Failures",
        "metrics": [["IndiWebPros/LMS", "AuthFailures", { "stat": "Sum", "period": 300 }]],
        "view": "timeSeries",
        "period": 300
      }
    },
    {
      "type": "metric",
      "x": 0, "y": 8, "width": 8, "height": 6,
      "properties": {
        "title": "🗄️ RDS CPU Utilization",
        "metrics": [
          ["AWS/RDS", "CPUUtilization", "DBInstanceIdentifier", "indiwebpros-lms-db", { "stat": "Average" }]
        ],
        "view": "timeSeries",
        "period": 300,
        "annotations": { "horizontal": [{ "color": "#ff6961", "value": 80, "label": "80% Alert" }] }
      }
    },
    {
      "type": "metric",
      "x": 8, "y": 8, "width": 8, "height": 6,
      "properties": {
        "title": "🔗 RDS Database Connections",
        "metrics": [
          ["AWS/RDS", "DatabaseConnections", "DBInstanceIdentifier", "indiwebpros-lms-db", { "stat": "Average" }]
        ],
        "view": "timeSeries",
        "period": 60,
        "annotations": { "horizontal": [{ "color": "#ff6961", "value": 90, "label": "90 conn limit" }] }
      }
    },
    {
      "type": "metric",
      "x": 16, "y": 8, "width": 8, "height": 6,
      "properties": {
        "title": "💾 RDS Free Storage",
        "metrics": [
          ["AWS/RDS", "FreeStorageSpace", "DBInstanceIdentifier", "indiwebpros-lms-db", { "stat": "Average", "label": "Free Storage (bytes)" }]
        ],
        "view": "timeSeries",
        "period": 300
      }
    },
    {
      "type": "metric",
      "x": 0, "y": 14, "width": 8, "height": 6,
      "properties": {
        "title": "🪣 S3 Requests",
        "metrics": [
          ["AWS/S3", "AllRequests", "BucketName", "indiwebpros-lms-bucket", "FilterId", "AllRequests", { "stat": "Sum" }]
        ],
        "view": "timeSeries",
        "period": 3600
      }
    },
    {
      "type": "metric",
      "x": 8, "y": 14, "width": 8, "height": 6,
      "properties": {
        "title": "📧 SES Email Metrics",
        "metrics": [
          ["AWS/SES", "Send", { "stat": "Sum", "label": "Sent" }],
          ["AWS/SES", "Bounce", { "stat": "Sum", "label": "Bounced" }],
          ["AWS/SES", "Complaint", { "stat": "Sum", "label": "Complained" }],
          ["AWS/SES", "Delivery", { "stat": "Sum", "label": "Delivered" }]
        ],
        "view": "timeSeries",
        "period": 3600
      }
    },
    {
      "type": "metric",
      "x": 16, "y": 14, "width": 8, "height": 6,
      "properties": {
        "title": "⏱️ API Latency (ms)",
        "metrics": [["IndiWebPros/LMS", "APILatency", { "stat": "p99", "period": 300, "label": "p99" }],
                    ["IndiWebPros/LMS", "APILatency", { "stat": "p95", "period": 300, "label": "p95" }],
                    ["IndiWebPros/LMS", "APILatency", { "stat": "Average", "period": 300, "label": "avg" }]],
        "view": "timeSeries",
        "period": 300
      }
    },
    {
      "type": "metric",
      "x": 0, "y": 20, "width": 8, "height": 6,
      "properties": {
        "title": "🎓 Enrollments Created",
        "metrics": [["IndiWebPros/LMS", "EnrollmentsCreated", { "stat": "Sum", "period": 3600 }]],
        "view": "timeSeries",
        "period": 3600
      }
    },
    {
      "type": "metric",
      "x": 8, "y": 20, "width": 8, "height": 6,
      "properties": {
        "title": "🌐 CloudFront Requests",
        "metrics": [
          ["AWS/CloudFront", "Requests", "DistributionId", "YOUR_DISTRIBUTION_ID", "Region", "Global", { "stat": "Sum" }],
          ["AWS/CloudFront", "5xxErrorRate", "DistributionId", "YOUR_DISTRIBUTION_ID", "Region", "Global", { "stat": "Average", "label": "5xx Rate %" }]
        ],
        "view": "timeSeries",
        "period": 300
      }
    },
    {
      "type": "metric",
      "x": 16, "y": 20, "width": 8, "height": 6,
      "properties": {
        "title": "📄 Certificates Generated",
        "metrics": [["IndiWebPros/LMS", "CertificatesGenerated", { "stat": "Sum", "period": 3600 }]],
        "view": "timeSeries",
        "period": 3600
      }
    }
  ]
}
