{
  "_comment": "CloudFront Distribution Configuration — IndiWebPros LMS",
  "_note": "Replace ACCOUNT_ID, BUCKET_NAME, OAC_ID with actual values",
  "_apply_via": "aws cloudfront create-distribution --distribution-config file://distribution-config.json",

  "CallerReference": "indiwebpros-lms-dist-2026",
  "Comment": "IndiWebPros LMS — CDN Distribution",
  "Enabled": true,
  "HttpVersion": "http2and3",
  "IsIPV6Enabled": true,
  "PriceClass": "PriceClass_All",

  "Origins": {
    "Quantity": 1,
    "Items": [
      {
        "Id": "S3-indiwebpros-lms-bucket",
        "DomainName": "indiwebpros-lms-bucket.s3.us-east-1.amazonaws.com",
        "S3OriginConfig": {
          "OriginAccessIdentity": ""
        },
        "OriginAccessControlId": "OAC_ID_PLACEHOLDER",
        "ConnectionAttempts": 3,
        "ConnectionTimeout": 10,
        "OriginShield": {
          "Enabled": true,
          "OriginShieldRegion": "us-east-1"
        }
      }
    ]
  },

  "DefaultCacheBehavior": {
    "TargetOriginId": "S3-indiwebpros-lms-bucket",
    "ViewerProtocolPolicy": "redirect-to-https",
    "Compress": true,
    "AllowedMethods": {
      "Quantity": 2,
      "Items": ["GET", "HEAD"],
      "CachedMethods": {
        "Quantity": 2,
        "Items": ["GET", "HEAD"]
      }
    },
    "CachePolicyId": "658327ea-f89d-4fab-a63d-7e88639e58f6",
    "OriginRequestPolicyId": "88a5eaf4-2fd4-4709-b370-b4c650ea3fcf",
    "ResponseHeadersPolicyId": "5cc3b908-e619-4b99-88e5-2cf7f45965bd",
    "TrustedKeyGroups": {
      "Enabled": false,
      "Quantity": 0,
      "Items": []
    }
  },

  "CacheBehaviors": {
    "Quantity": 6,
    "Items": [
      {
        "_comment": "Static Assets — 24 hour cache",
        "PathPattern": "/assets/*",
        "TargetOriginId": "S3-indiwebpros-lms-bucket",
        "ViewerProtocolPolicy": "redirect-to-https",
        "Compress": true,
        "DefaultTTL": 86400,
        "MaxTTL": 86400,
        "MinTTL": 0,
        "AllowedMethods": { "Quantity": 2, "Items": ["GET", "HEAD"] }
      },
      {
        "_comment": "Images — 7 day cache",
        "PathPattern": "/images/*",
        "TargetOriginId": "S3-indiwebpros-lms-bucket",
        "ViewerProtocolPolicy": "redirect-to-https",
        "Compress": true,
        "DefaultTTL": 604800,
        "MaxTTL": 604800,
        "MinTTL": 3600,
        "AllowedMethods": { "Quantity": 2, "Items": ["GET", "HEAD"] }
      },
      {
        "_comment": "Course Thumbnails — 30 day cache",
        "PathPattern": "/thumbnails/*",
        "TargetOriginId": "S3-indiwebpros-lms-bucket",
        "ViewerProtocolPolicy": "redirect-to-https",
        "Compress": true,
        "DefaultTTL": 2592000,
        "MaxTTL": 2592000,
        "MinTTL": 3600,
        "AllowedMethods": { "Quantity": 2, "Items": ["GET", "HEAD"] }
      },
      {
        "_comment": "Certificates — No cache (private, download only)",
        "PathPattern": "/certificates/*",
        "TargetOriginId": "S3-indiwebpros-lms-bucket",
        "ViewerProtocolPolicy": "https-only",
        "Compress": false,
        "DefaultTTL": 0,
        "MaxTTL": 0,
        "MinTTL": 0,
        "AllowedMethods": { "Quantity": 2, "Items": ["GET", "HEAD"] },
        "TrustedKeyGroups": {
          "Enabled": true,
          "Quantity": 1,
          "Items": ["YOUR_KEY_GROUP_ID"]
        }
      },
      {
        "_comment": "Lesson Videos — 24h cache, HLS-ready with range requests",
        "PathPattern": "/lessons/*",
        "TargetOriginId": "S3-indiwebpros-lms-bucket",
        "ViewerProtocolPolicy": "redirect-to-https",
        "Compress": false,
        "DefaultTTL": 86400,
        "MaxTTL": 86400,
        "MinTTL": 0,
        "AllowedMethods": {
          "Quantity": 3,
          "Items": ["GET", "HEAD", "OPTIONS"],
          "CachedMethods": { "Quantity": 2, "Items": ["GET", "HEAD"] }
        }
      },
      {
        "_comment": "Avatars — 7 day cache",
        "PathPattern": "/avatars/*",
        "TargetOriginId": "S3-indiwebpros-lms-bucket",
        "ViewerProtocolPolicy": "redirect-to-https",
        "Compress": true,
        "DefaultTTL": 604800,
        "MaxTTL": 604800,
        "MinTTL": 0,
        "AllowedMethods": { "Quantity": 2, "Items": ["GET", "HEAD"] }
      }
    ]
  },

  "ViewerCertificate": {
    "_comment": "Use CloudFront default cert until custom domain is ready. Switch to ACM cert for learn.indiwebpros.in",
    "CloudFrontDefaultCertificate": true,
    "MinimumProtocolVersion": "TLSv1.2_2021",
    "SSLSupportMethod": "sni-only"
  },

  "Restrictions": {
    "GeoRestriction": {
      "RestrictionType": "none",
      "Quantity": 0
    }
  },

  "WebACLId": "",

  "CustomErrorResponses": {
    "Quantity": 2,
    "Items": [
      {
        "ErrorCode": 403,
        "ResponsePagePath": "/errors/403.html",
        "ResponseCode": "403",
        "ErrorCachingMinTTL": 300
      },
      {
        "ErrorCode": 404,
        "ResponsePagePath": "/errors/404.html",
        "ResponseCode": "404",
        "ErrorCachingMinTTL": 300
      }
    ]
  }
}
