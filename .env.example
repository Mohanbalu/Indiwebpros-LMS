# Root environment variable template for IndiWebPros LMS

PORT=5000
NODE_ENV=development

# Database Url
DATABASE_URL=postgresql://postgres:password@localhost:5432/indiwebpros_lms?schema=public

# Security Settings
JWT_SECRET=dev_jwt_secret_key_123456
JWT_REFRESH_SECRET=dev_jwt_refresh_secret_key_123456

# AWS Config
AWS_REGION=us-east-1
AWS_BUCKET=indiwebpros-lms-dev-bucket
AWS_ACCESS_KEY=mock_aws_access_key
AWS_SECRET_KEY=mock_aws_secret_key

# SMTP Server Configurations
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=mock_smtp_user
SMTP_PASSWORD=mock_smtp_password

# Client Location
FRONTEND_URL=http://localhost:5173
