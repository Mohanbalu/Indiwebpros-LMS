{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["../backend/src/*"],
      "@backend/*": ["../backend/src/*"],
      "@frontend/*": ["../frontend/src/*"]
    }
  },
  "include": ["**/*.ts", "**/*.spec.ts", "**/*.test.ts"]
}
