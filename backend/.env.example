# Environment configuration template for IndiWebPros LMS Backend

PORT=5000
NODE_ENV=development

# Database Url
DATABASE_URL=postgresql://postgres:password@localhost:5432/indiwebpros_lms?schema=public

# Security Settings
JWT_SECRET=dev_jwt_secret_key_123456
JWT_REFRESH_SECRET=dev_jwt_refresh_secret_key_123456

# AWS Config
AWS_REGION=us-east-1
AWS_BUCKET=indiwebpros-lms-dev-bucket
AWS_ACCESS_KEY=mock_aws_access_key
AWS_SECRET_KEY=mock_aws_secret_key

EMAIL_PROVIDER=brevo
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=b23214001@smtp-brevo.com
SMTP_PASSWORD=your_smtp_password_here
SMTP_FROM_NAME=IndiWebPros-LMS
SMTP_FROM_EMAIL=admin@indiwebpros.in
SMTP_SECURE=false

# Client Location
FRONTEND_URL=http://localhost:5173
